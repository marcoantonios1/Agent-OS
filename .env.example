# ── LLM gateway (required) ────────────────────────────────────────────────────
COSTGUARD_URL=http://localhost:8080

# ── Server (optional) ─────────────────────────────────────────────────────────
PORT=9091
LOG_LEVEL=info
SESSION_TTL=24h
BUILDER_SANDBOX_DIR=workspace

# ── Google (Gmail + Google Calendar) ─────────────────────────────────────────
# A single token covers both Gmail and Google Calendar.
# Obtain via: GOOGLE_CLIENT_ID=<id> GOOGLE_CLIENT_SECRET=<secret> go run ./cmd/tool/googleauth/
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# ── Microsoft (Outlook Mail + Outlook Calendar) ───────────────────────────────
# A single token covers both Outlook Mail and Outlook Calendar.
# Obtain via: MICROSOFT_CLIENT_ID=<id> go run ./cmd/tool/microsoftauth/
MICROSOFT_CLIENT_ID=your-app-id
MICROSOFT_REFRESH_TOKEN=your-refresh-token

# ── Discord channel ───────────────────────────────────────────────────────────
# Without DISCORD_BOT_TOKEN the server starts normally — Discord is just disabled.
# Create a bot at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_GUILD_ID=your-guild-id   # optional — limits bot to one server
# DISCORD_PREFIX=!ai                # optional — require prefix in server channels; DMs always routed

# ── Research Agent (web search) ───────────────────────────────────────────────
# Required to enable web_search and web_fetch tools. Without it the Research
# Agent still starts but has no live search — it falls back to LLM knowledge.
# Get a free key at: https://brave.com/search/api/
SEARCH_API_KEY=your-brave-api-key
SEARCH_PROVIDER=brave   # only "brave" is supported today

# ── Persistence ───────────────────────────────────────────────────────────────
# Path to the SQLite database file for persistent user profiles and project state.
# When unset the server uses in-memory stores — data is lost on restart.
# The parent directory is created automatically if it does not exist.
# SQLITE_PATH=./data/agentos.db

# ── LLM gateway (required) ────────────────────────────────────────────────────
COSTGUARD_URL=http://host.docker.internal:8080
# COSTGUARD_API_KEY=your-api-key   # optional bearer token for the gateway

# ── Agent models (optional) ───────────────────────────────────────────────────
# Model identifier passed to Costguard for each agent. Defaults to gemma4:26b.
# Tip: use a small fast model for the classifier and profile observer —
#      they only produce short structured output and don't need a large model.
#
# COMMS_MODEL=gemma4:26b
# BUILDER_MODEL=gemma4:26b
# RESEARCH_MODEL=gemma4:26b
# CLASSIFIER_MODEL=llama3.2:3b    # small model works well here — just outputs JSON
# PROFILE_MODEL=llama3.2:3b       # background personality observer — small + fast is fine

# ── Server (optional) ─────────────────────────────────────────────────────────
PORT=9091
LOG_LEVEL=info
SESSION_TTL=24h
BUILDER_SANDBOX_DIR=workspace

# ── Persistence ───────────────────────────────────────────────────────────────
# Path to the SQLite database. Without this, all data (profiles, projects,
# reminders, personality signals) is lost on restart.
SQLITE_PATH=./data/agentos.db

# ── Google (Gmail + Google Calendar) ─────────────────────────────────────────
# A single token covers both Gmail and Google Calendar.
# Obtain via: GOOGLE_CLIENT_ID=<id> GOOGLE_CLIENT_SECRET=<secret> go run ./cmd/tool/googleauth/
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# ── Microsoft (Outlook Mail + Outlook Calendar) ───────────────────────────────
# A single token covers both Outlook Mail and Outlook Calendar.
# Obtain via: MICROSOFT_CLIENT_ID=<id> go run ./cmd/tool/microsoftauth/
MICROSOFT_CLIENT_ID=your-app-id
MICROSOFT_REFRESH_TOKEN=your-refresh-token

# ── Discord channel ───────────────────────────────────────────────────────────
# Without DISCORD_BOT_TOKEN the server starts normally — Discord is just disabled.
# Create a bot at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_GUILD_ID=your-guild-id   # optional — limits bot to one server
# DISCORD_PREFIX=!ai               # optional — require prefix in server channels; DMs always routed

# ── WhatsApp channel ──────────────────────────────────────────────────────────
# Enables WhatsApp via the WA Web protocol. On first run a QR code is printed
# to the logs — scan it with WhatsApp → Linked Devices → Link a Device.
# The session is saved to WHATSAPP_STORE_PATH and survives restarts.
#
# WHATSAPP_ALLOWED_JID: only messages from this JID are handled.
# Format: <country-code><number>@s.whatsapp.net (e.g. 96170123456@s.whatsapp.net)
# To find your JID: leave WHATSAPP_ALLOWED_JID unset on first run — the server
# logs the JID of every incoming message so you can copy it.
WHATSAPP_STORE_PATH=whatsapp.db
WHATSAPP_ALLOWED_JID=96170123456@s.whatsapp.net
#VOICE_TRANSCRIPTION=enabled
#VOICE_TTS=enabled
#VOICE_TTS_VOICE=alloy   # or nova, shimmer, echo, fable, onyx

# ── Research Agent (web search) ───────────────────────────────────────────────
# Without SEARCH_API_KEY the Research Agent still starts but has no live search.
# Get a free key at: https://brave.com/search/api/
# SEARCH_API_KEY=your-brave-api-key
# SEARCH_PROVIDER=brave   # only "brave" is supported today

# ── Heartbeat worker ──────────────────────────────────────────────────────────
# A background worker that runs a prompt on a fixed interval and delivers the
# response to you via the configured channel (Discord or WhatsApp).
# Disabled by default — set HEARTBEAT_INTERVAL to enable.
#
# The prompt is resolved in this order:
#   1. {BUILDER_SANDBOX_DIR}/HEARTBEAT.md  — edit this file to change the checklist
#      without restarting. Copy it in with: docker compose cp HEARTBEAT.md agentos:/app/workspace/
#   2. HEARTBEAT_PROMPT env var             — fallback when no HEARTBEAT.md exists
#   3. Built-in default                    — "Check my emails for anything urgent
#                                            and summarize my calendar for today."
#
# HEARTBEAT_INTERVAL=30m                           # any Go duration: 30m, 1h, 2h
# HEARTBEAT_USER_ID=96170123456@s.whatsapp.net     # your user / WhatsApp JID
# HEARTBEAT_SESSION_ID=heartbeat                   # dedicated session (keeps history separate)
# HEARTBEAT_CHANNEL=whatsapp                       # discord | whatsapp | web
# HEARTBEAT_PROMPT=Check my emails and calendar.   # optional — overridden by HEARTBEAT.md

# ── Context compaction ────────────────────────────────────────────────────────
# Long sessions accumulate history that eventually exceeds model context limits.
# When history exceeds this estimated token count, older turns are automatically
# summarised and replaced with a single summary turn before dispatch.
# The 10 most recent turns are always kept verbatim.
# Set to 0 to disable compaction entirely.
#
# COMPACTION_THRESHOLD=6000   # default — lower this for models with small context windows
